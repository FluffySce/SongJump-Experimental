generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?
  createdAt DateTime @default(now())

  oauthAccounts OAuthAccount[]
  transferJobs  TransferJob[]
}

model OAuthAccount {
  id             String   @id @default(uuid())
  provider       Provider
  providerUserId String

  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([provider, providerUserId])
}

model TransferJob {
  id               String         @id @default(uuid())
  sourceProvider   Provider       @default(spotify)
  sourcePlaylistId String
  sourcePlaylistName String?
  targetProvider   Provider       @default(google)
  
  totalTracks      Int            @default(0)
  processedTracks  Int            @default(0)
  successCount     Int            @default(0)
  failureCount     Int            @default(0)
  
  status           TransferStatus @default(PENDING)
  errorMessage     String?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  items TransferItem[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model TransferItem {
  id             String      @id @default(uuid())
  trackName      String
  artistName     String
  status         TrackStatus @default(PENDING)
  youtubeMusicId String?
  errorMessage   String?

  createdAt DateTime @default(now())

  transferJob   TransferJob @relation(fields: [transferJobId], references: [id])
  transferJobId String

  @@index([transferJobId])
}

enum Provider {
  spotify
  google
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum TrackStatus {
  PENDING
  FOUND
  NOT_FOUND
  FAILED
}