generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String?
  createdAt DateTime @default(now())

  oauthAccounts OAuthAccount[]
  transferJobs  TransferJob[]
}

model OAuthAccount {
  id             String   @id @default(uuid())
  provider       String   // "spotify" | "google"
  providerUserId String

  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([provider, providerUserId])
}

model TransferJob {
  id               String   @id @default(uuid())
  sourceProvider   String   @default("spotify")  // "spotify" | "google"
  sourcePlaylistId String
  sourcePlaylistName String?
  targetProvider   String   @default("google")   // "spotify" | "google"
  
  totalTracks      Int      @default(0)
  processedTracks  Int      @default(0)
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  
  status           String   @default("PENDING")  // PENDING | PROCESSING | COMPLETED | PARTIAL | FAILED
  errorMessage     String?
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  completedAt      DateTime?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  items TransferItem[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model TransferItem {
  id             String   @id @default(uuid())
  trackName      String
  artistName     String
  status         String   @default("PENDING")  // PENDING | FOUND | NOT_FOUND | FAILED
  youtubeMusicId String?
  errorMessage   String?

  createdAt DateTime @default(now())

  transferJob   TransferJob @relation(fields: [transferJobId], references: [id])
  transferJobId String

  @@index([transferJobId])
}

// Note: Enum values are stored as strings in SQLite
// Provider: "spotify" | "google"
// TransferStatus: "PENDING" | "PROCESSING" | "COMPLETED" | "PARTIAL" | "FAILED"
// TrackStatus: "PENDING" | "FOUND" | "NOT_FOUND" | "FAILED"